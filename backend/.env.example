APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/project_eval
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
API_KEY_ENCRYPTION_KEY=replace-with-a-valid-fernet-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
RATE_LIMIT_DEFAULT=120/minute
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
STORAGE_ROOT=../uploads
MAX_UPLOAD_BATCH_FILES=300
MAX_UPLOAD_FILE_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=["pdf","docx","txt"]
ALLOWED_ARCHIVE_EXTENSIONS=["zip"]
MAX_ARCHIVE_ENTRIES=500
OLLAMA_BASE_URL=http://localhost:11434
BATCH_MAX_PARALLEL_EVALUATIONS=3
BATCH_MAX_PARALLEL_EVALUATIONS_GROQ=1
BATCH_RATE_LIMIT_RETRY_ATTEMPTS=3
BATCH_RATE_LIMIT_RETRY_BASE_SECONDS=2
